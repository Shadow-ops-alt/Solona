# --- Server ---
# PORT=8787
# NODE_ENV=production
# WEB_BASE_URL=http://localhost:5173

# --- Solana / Anchor ---
# Devnet by default; override for mainnet or a private RPC.
# SOLANA_RPC_URL=https://api.devnet.solana.com

# Relayer signing key as a JSON array of 64 bytes (Solana keypair format).
# Generate one with: solana-keygen new -o relayer-keypair.json --no-bip39-passphrase
# Then: cat relayer-keypair.json
# RELAYER_PRIVATE_KEY=[12,34,...]

# --- Bubblegum cNFT receipts ---
# Optional. If unset, /api/claim will skip the NFT mint and return nftTx=null.
# Create a Merkle tree + collection mint with the metaplex CLI/SDK first.
# MERKLE_TREE_ADDRESS=
# COLLECTION_MINT=

# --- Agent console (PIN-gated) ---
# Demo: plain PIN. Defaults to 1234 if neither this nor the hash is set.
# AGENT_PIN=1234

# Production: set both. Hash is sha256(salt + pin) hex.
# AGENT_PIN_HASH=
# AGENT_PIN_SALT=
